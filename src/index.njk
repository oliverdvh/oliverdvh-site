---
layout: base.njk
permalink: /
activeNav: home
pageTitle: "Oliver Dudok van Heel — Writer & sustainability strategist"
description: "Oliver Dudok van Heel writes and advises on the corporate sustainability transition and the cultural narratives shaping our climate future. Author of Changing Stories, Finding Hope (2027)."

hero:
  eyebrow: "Writer · Sustainability advisor"
  headline: "The world we have is not inevitable."
  headlineItalic: "We can create better businesses and better societies."
  lede: "Hello — I'm Oliver. I write, teach and advise on corporate sustainability, and on the cultural stories that quietly decide whether any of it works. After twenty-five years inside the system, I've come to think the stories matter more than the spreadsheets."
  primaryCtaLabel: "Work with me"
  primaryCtaUrl: "/speaking/"
  secondaryCtaLabel: "Read recent writing"
  secondaryCtaUrl: "/writing/"

pillarsIntro:
  eyebrow: "What I do"
  heading: "Two threads of the same argument"
  lede: "My consulting work and my writing pull on the same thread. One is about how companies actually change. The other is about why so many of us — leaders included — are quietly convinced they can't."

pillarOne:
  num: "Pillar one"
  heading: "Corporate sustainability, honestly"
  body: "I help boards and executive teams find the business case that actually holds — and a transition plan that survives the politics. No jargon, no greenwash, no pretending that easy answers exist."
  bullets:
    - "Sustainability as competitive strategy, not compliance"
    - "Transition planning that boards will fund"
    - "Building resilience in a changing world"
    - "Making CSRD work for you, not against you"

pillarTwo:
  num: "Pillar two"
  heading: "Changing the stories underneath"
  body: "I write and speak about why we keep losing climate arguments we should be winning — and what changes when we challenge the deeper stories about growth, competition and human nature that keep us stuck."
  bullets:
    - "Hope as a strategy, not a mood"
    - "Why people can be trusted"
    - "Cooperation, competition and what we get wrong about both"
    - "Music, art and the power of imagination"

writingTeaser:
  eyebrow: "Latest writing"
  heading: "From the Substack & commissioned essays"
  ctaLabel: "All writing →"
  ctaUrl: "/writing/"
  fallbackPosts:
    - { date: "June 2026", title: "Less is more. Really.", url: "https://changingstories.substack.com/p/less-is-more-really" }
    - { date: "May 2026", title: "A time to stop", url: "https://changingstories.substack.com/p/a-time-to-stop" }
    - { date: "May 2026", title: "How four myth-busting women helped shape a better world", url: "https://changingstories.substack.com/p/how-four-myth-busting-women-helped" }
    - { date: "May 2026", title: "What bees and a pioneering woman taught me about competition", url: "https://changingstories.substack.com/p/what-bees-and-a-pioneering-woman" }

bookPanel:
  eyebrow: "A book · Early 2027"
  heading: "Changing Stories, Finding Hope"
  body1: "A book about the stories we've been told about ourselves — that we're selfish, competitive, separate from nature, destined to keep growing — and why almost none of them are true."
  body2: "For anyone who senses that the way things are is not the way they have to be. Out early 2027."

subscribe:
  eyebrow: "Newsletter"
  heading: "Changing Stories on Substack"
  body: "Roughly weekly essays on sustainability, narrative change and the politics of the transition — plus the occasional dispatch from the Highlands. Free to read."
---

<section class="hero">
  <div class="container hero-grid">
    <div>
      <span class="eyebrow">{{ hero.eyebrow }}</span>
      <h1>{{ hero.headline }} <span class="italic-accent">{{ hero.headlineItalic }}</span></h1>
      <p class="lede">{{ hero.lede }}</p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-arrow" href="{{ hero.primaryCtaUrl }}">{{ hero.primaryCtaLabel }}</a>
        <a class="btn btn-secondary" href="{{ hero.secondaryCtaUrl }}">{{ hero.secondaryCtaLabel }}</a>
      </div>
    </div>
    <div class="hero-portrait">
      <img src="/assets/oliver.jpg" alt="Portrait of Oliver Dudok van Heel" />
    </div>
  </div>
</section>

<section class="section section-soft">
  <div class="container">
    <span class="eyebrow">{{ pillarsIntro.eyebrow }}</span>
    <h2>{{ pillarsIntro.heading }}</h2>
    <p class="lede mt-1" style="max-width: 56ch;">{{ pillarsIntro.lede }}</p>

    <div class="pillars mt-3">
      <article class="pillar">
        <span class="pillar-num">{{ pillarOne.num }}</span>
        <h3>{{ pillarOne.heading }}</h3>
        <p>{{ pillarOne.body }}</p>
        <ul>
          {% for b in pillarOne.bullets %}<li>{{ b }}</li>{% endfor %}
        </ul>
      </article>
      <article class="pillar">
        <span class="pillar-num">{{ pillarTwo.num }}</span>
        <h3>{{ pillarTwo.heading }}</h3>
        <p>{{ pillarTwo.body }}</p>
        <ul>
          {% for b in pillarTwo.bullets %}<li>{{ b }}</li>{% endfor %}
        </ul>
      </article>
    </div>
  </div>
</section>

<section class="section section-tight">
  <div class="container text-center">
    <span class="eyebrow">Affiliations</span>
    <div class="logos mt-2">
      <a href="{{ site.cislUrl }}" target="_blank" rel="noopener">Cambridge Institute for Sustainability Leadership</a>
      <a href="{{ site.cuspUrl }}" target="_blank" rel="noopener">Centre for the Understanding of Sustainable Prosperity</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div style="display:flex; justify-content:space-between; align-items:end; gap:1rem; flex-wrap:wrap; margin-bottom:2rem;">
      <div>
        <span class="eyebrow">{{ writingTeaser.eyebrow }}</span>
        <h2 class="mb-0">{{ writingTeaser.heading }}</h2>
      </div>
      <a class="btn btn-secondary" href="{{ writingTeaser.ctaUrl }}">{{ writingTeaser.ctaLabel }}</a>
    </div>

    <div class="writing-list" data-substack-feed="true" data-limit="4">
      {% for p in writingTeaser.fallbackPosts %}
      <a class="writing-item" href="{{ p.url }}" target="_blank" rel="noopener">
        <span class="writing-date">{{ p.date }}</span>
        <span class="writing-title">{{ p.title }}</span>
        <span class="writing-meta">Substack</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section-soft">
  <div class="container">
    <div class="book-panel">
      <div class="book-cover">
        <div class="book-cover-text">Changing Stories,<br/><em>Finding Hope.</em></div>
      </div>
      <div>
        <span class="eyebrow">{{ bookPanel.eyebrow }}</span>
        <h2>{{ bookPanel.heading }}</h2>
        <p>{{ bookPanel.body1 }}</p>
        <p>{{ bookPanel.body2 }}</p>
        <div class="hero-actions mt-2">
          <a class="btn btn-primary btn-arrow" href="{{ site.bookSiteUrl }}" target="_blank" rel="noopener">Visit the book site</a>
          <a class="btn btn-secondary" href="/book/">More about the book</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="subscribe-cta">
      <span class="eyebrow" style="color: rgba(255, 250, 242, 0.7);">{{ subscribe.eyebrow }}</span>
      <h2>{{ subscribe.heading }}</h2>
      <p>{{ subscribe.body }}</p>
      <a class="btn btn-primary btn-arrow" href="{{ site.substackUrl }}" target="_blank" rel="noopener">Subscribe on Substack</a>
    </div>
  </div>
</section>

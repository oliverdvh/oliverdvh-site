---
layout: base.njk
permalink: /writing/
activeNav: writing
pageTitle: "Writing — Oliver Dudok van Heel"
description: "Essays and long-form by Oliver Dudok van Heel on corporate sustainability strategy and narrative change."

hero:
  eyebrow: "Writing"
  headline: "Essays, long reads, and a book in the works."
  lede: "Most of my new writing appears first on Substack. Commissioned pieces, interviews and longer work elsewhere are gathered below."
  primaryCtaLabel: "Read on Substack"
  primaryCtaUrl: "https://changingstories.substack.com"
  secondaryCtaLabel: "The book site"
  secondaryCtaUrl: "https://www.changingstoriesbook.com"

threads:
  eyebrow: "What I tend to write about"
  heading: "The two threads"
  cards:
    - { eyebrow: "Thread one", heading: "Corporate sustainability, honestly", body: "Transition planning that actually gets funded. Making CSRD work for you. The business case in a post-anti-ESG world. How CFOs and CSOs talk to each other when the stakes get real." }
    - { eyebrow: "Thread two", heading: "Changing the stories underneath", body: "Hope as a strategy. Why doomism keeps funding itself. Cooperation, competition, and the bad evolutionary biology we still teach. Music, art and the climate imagination." }

recent:
  eyebrow: "From the Substack"
  heading: "Recent essays"
  fallbackPosts:
    - { date: "June 2026", title: "Less is more. Really.", url: "https://changingstories.substack.com/p/less-is-more-really" }
    - { date: "May 2026", title: "A time to stop", url: "https://changingstories.substack.com/p/a-time-to-stop" }
    - { date: "May 2026", title: "How four myth-busting women helped shape a better world", url: "https://changingstories.substack.com/p/how-four-myth-busting-women-helped" }
    - { date: "May 2026", title: "What bees and a pioneering woman taught me about competition", url: "https://changingstories.substack.com/p/what-bees-and-a-pioneering-woman" }
    - { date: "April 2026", title: "Despite our differences", url: "https://changingstories.substack.com/p/despite-our-differences" }
    - { date: "April 2026", title: "Normalising the abnormal", url: "https://changingstories.substack.com/p/normalising-the-abnormal" }

elsewhere:
  eyebrow: "Elsewhere on the web"
  heading: "Where my writing lives"
  lede: "My new work appears first on Substack. Older pieces written under previous roles — at Kearney and Aldersgate Group — are gathered below, alongside major reports I authored at Freshfields and Aldersgate, hosted here so they stay reachable."
  items:
    - { date: "Ongoing", title: "Changing Stories — my Substack", url: "https://changingstories.substack.com", meta: "changingstories.substack.com" }
    - { date: "2017–2022", title: "Sustainability Matters — written during my time at Kearney", url: "https://www.kearney.com/service/sustainability/sustainability-matters", meta: "kearney.com" }

reports:
  eyebrow: "Reports I've authored"
  heading: "Impactful reports"
  lede: "Here are two examples of content I created and wrote that helped shift narratives at the national — UK — and local NYC level."
  items:
    - title: "An Economy That Works: Strong Today, Great Tomorrow"
      meta: "Aldersgate Group · 2022"
      desc: "How Britain can make the transition to an economy that delivers prosperity, competitiveness and sustainability for companies and citizens — written during my time with the Aldersgate Group."
      cover: "/assets/reports/an-economy-that-works-cover.png"
      coverAlt: "Cover of An Economy That Works"
      pdf: "/assets/reports/an-economy-that-works.pdf"
      original: "https://www.aldersgategroup.org.uk/publications/post/an-economy-that-works/"
    - title: "Circular City — New York"
      meta: "Freshfields"
      desc: "A study of how circular-economy principles can reshape a major global city, written during my time at Freshfields. Originally published on the Freshfields-hosted Circular City site."
      cover: "/assets/reports/circular-city-cover.png"
      coverAlt: "Cover of the Circular City Report"
      pdf: "/assets/reports/circular-city-report.pdf"
      original: ""

newsletter:
  eyebrow: "Newsletter"
  heading: "The next essay, straight to your inbox"
  body: "Free, roughly weekly, unsubscribe whenever you like. No tracking, no upsell."
---

<section class="hero">
  <div class="container">
    <span class="eyebrow">{{ hero.eyebrow }}</span>
    <h1>{{ hero.headline }}</h1>
    <p class="lede mt-1">{{ hero.lede }}</p>
    <div class="hero-actions mt-2">
      <a class="btn btn-primary btn-arrow" href="{{ hero.primaryCtaUrl }}" target="_blank" rel="noopener">{{ hero.primaryCtaLabel }}</a>
      <a class="btn btn-secondary" href="{{ hero.secondaryCtaUrl }}" target="_blank" rel="noopener">{{ hero.secondaryCtaLabel }}</a>
    </div>
  </div>
</section>

<section class="section section-soft">
  <div class="container">
    <span class="eyebrow">{{ threads.eyebrow }}</span>
    <h2>{{ threads.heading }}</h2>
    <div class="cards mt-3">
      {% for c in threads.cards %}
      <article class="card">
        <span class="card-eyebrow">{{ c.eyebrow }}</span>
        <h4>{{ c.heading }}</h4>
        <p>{{ c.body }}</p>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <span class="eyebrow">{{ recent.eyebrow }}</span>
    <h2>{{ recent.heading }}</h2>
    <div class="writing-list mt-2" data-substack-feed="true" data-limit="6">
      {% for p in recent.fallbackPosts %}
      <a class="writing-item" href="{{ p.url }}" target="_blank" rel="noopener">
        <span class="writing-date">{{ p.date }}</span>
        <span class="writing-title">{{ p.title }}</span>
        <span class="writing-meta">Substack</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section-soft">
  <div class="container">
    <span class="eyebrow">{{ elsewhere.eyebrow }}</span>
    <h2>{{ elsewhere.heading }}</h2>
    <p class="lede mt-1" style="max-width: 60ch;">{{ elsewhere.lede }}</p>

    <div class="writing-list mt-2">
      {% for item in elsewhere.items %}
      <a class="writing-item" href="{{ item.url }}" target="_blank" rel="noopener">
        <span class="writing-date">{{ item.date }}</span>
        <span class="writing-title">{{ item.title }}</span>
        <span class="writing-meta">{{ item.meta }}</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <span class="eyebrow">{{ reports.eyebrow }}</span>
    <h2>{{ reports.heading }}</h2>
    <p class="lede mt-1" style="max-width: 62ch;">{{ reports.lede }}</p>

    <div class="reports">
      {% for r in reports.items %}
      <article class="report">
        <a class="report-cover" href="{{ r.pdf }}" target="_blank" rel="noopener" aria-label="Download {{ r.title }} PDF">
          <img src="{{ r.cover }}" alt="{{ r.coverAlt }}" loading="lazy" />
        </a>
        <div class="report-body">
          <span class="report-eyebrow">{{ r.meta }}</span>
          <h3 class="report-title">{{ r.title }}</h3>
          <p class="report-desc">{{ r.desc }}</p>
          <div class="report-actions">
            <a class="btn btn-primary btn-arrow" href="{{ r.pdf }}" target="_blank" rel="noopener">Download PDF</a>
            {% if r.original %}<a class="btn btn-secondary" href="{{ r.original }}" target="_blank" rel="noopener">Original page</a>{% endif %}
          </div>
        </div>
      </article>
      {% endfor %}
    </div>

    <p class="muted mt-4" style="font-family: var(--font-ui); font-size: 0.92rem;">Editors and producers — see <a href="/contact/">contact</a> or email <a href="mailto:{{ site.email }}">{{ site.email }}</a>.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="subscribe-cta">
      <span class="eyebrow" style="color: rgba(255, 250, 242, 0.7);">{{ newsletter.eyebrow }}</span>
      <h2>{{ newsletter.heading }}</h2>
      <p>{{ newsletter.body }}</p>
      <a class="btn btn-primary btn-arrow" href="{{ site.substackUrl }}" target="_blank" rel="noopener">Subscribe on Substack</a>
    </div>
  </div>
</section>

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="brand" style="margin-bottom: 0.8rem;">
          <svg class="brand-mark" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
            <circle cx="16" cy="16" r="11"/>
            <path d="M 22.5 8.5 A 11 11 0 0 1 22.5 23.5" stroke="#c2562e" stroke-width="2.6" fill="none"/>
          </svg>
          <span class="brand-name">{{ site.brandName }}</span>
        </div>
        <p class="footer-tagline">{{ site.footerTagline }}</p>
      </div>
      <div class="footer-col">
        <h5>Site</h5>
        <ul>
          {% for item in site.nav %}{% if item.key != 'home' %}
            <li><a href="{{ item.url }}">{{ item.label | safe }}</a></li>
          {% endif %}{% endfor %}
        </ul>
      </div>
      <div class="footer-col">
        <h5>Elsewhere</h5>
        <ul>
          <li><a href="{{ site.substackUrl }}" target="_blank" rel="noopener">Substack</a></li>
          <li><a href="{{ site.bookSiteUrl }}" target="_blank" rel="noopener">The book site</a></li>
          <li><a href="mailto:{{ site.email }}">Email</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-base">
      <span>© {{ site.copyrightYear }} {{ site.brandName }}</span>
      <span>{{ site.basedIn }}</span>
    </div>
  </div>
</footer>

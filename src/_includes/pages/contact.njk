---
layout: base.njk
---

{# Split the email so it doesn't appear anywhere in the HTML as plain text.
   Reassembled in JS on user click below. #}
{% set _emailLocal = site.email.split('@')[0] %}
{% set _emailDomain = site.email.split('@')[1] %}

<section class="hero">
  <div class="container">
    <span class="eyebrow">{{ hero.eyebrow }}</span>
    <h1>{{ hero.headline }}</h1>
    <p class="lede mt-1">{{ hero.lede }}</p>
  </div>
</section>

<section class="section section-soft">
  <div class="container">
    <div class="split">
      <div>
        <form id="contact-form" class="form-grid" novalidate data-access-key="{{ site.web3formsAccessKey or '' }}">
          <div class="field">
            <label for="name">Your name</label>
            <input type="text" id="name" name="name" required autocomplete="name" />
          </div>
          <div class="field">
            <label for="org">Organisation (optional)</label>
            <input type="text" id="org" name="org" autocomplete="organization" />
          </div>
          <div class="field">
            <label for="reply_email">Your email</label>
            <input type="email" id="reply_email" name="reply_email" required autocomplete="email" />
          </div>
          <div class="field">
            <label for="topic">What's it about?</label>
            <select id="topic" name="topic" required>
              <option value="">Choose one…</option>
              {% for opt in topicOptions %}<option>{{ opt }}</option>{% endfor %}
            </select>
          </div>
          <div class="field">
            <label for="message">One paragraph</label>
            <textarea id="message" name="message" required placeholder="Audience, date, where, and what they need to walk away with."></textarea>
          </div>

          {# Honeypot — visually hidden, must remain empty. Real users won't see it. #}
          <div class="hp-field" aria-hidden="true">
            <label for="website">Website</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          {# Cloudflare Turnstile widget. Site key comes from CMS → Site-wide settings. #}
          {% if site.turnstileSiteKey %}
          <div class="cf-turnstile" data-sitekey="{{ site.turnstileSiteKey }}" data-theme="light"></div>
          {% endif %}
          {% if not site.web3formsAccessKey %}
          <p class="muted" style="font-family: var(--font-ui); font-size: 0.92rem;">
            (The contact form is not yet configured. Please use the email link in the sidebar.)
          </p>
          {% endif %}

          <button class="btn btn-primary btn-arrow" type="submit"{% if not site.web3formsAccessKey %} disabled{% endif %}>Send</button>
          <div id="form-status" role="status" aria-live="polite"></div>
        </form>
      </div>

      <aside>
        <h3>Prefer email?</h3>
        <p>
          <button type="button" id="reveal-email" class="reveal-link"
                  data-l="{{ _emailLocal }}"
                  data-d="{{ _emailDomain }}">
            Show my email address
          </button>
        </p>
        <p id="email-revealed" hidden></p>

        <h3 class="mt-3">{{ side.elsewhereHeading }}</h3>
        <ul style="list-style:none; padding:0; font-family: var(--font-ui);">
          <li style="margin-bottom: 0.5rem;"><a href="{{ site.substackUrl }}" target="_blank" rel="noopener">Substack — changingstories.substack.com</a></li>
          <li style="margin-bottom: 0.5rem;"><a href="{{ site.bookSiteUrl }}" target="_blank" rel="noopener">The book — changingstoriesbook.com</a></li>
        </ul>

        <h3 class="mt-3">{{ side.basedInHeading }}</h3>
        <p class="muted" style="font-family: var(--font-ui);">{{ side.basedIn }}</p>

        <h3 class="mt-3">{{ side.noteHeading }}</h3>
        <p style="font-family: var(--font-ui); font-size: 0.96rem; color: var(--ink-soft);">{{ side.noteBody }}</p>
      </aside>
    </div>
  </div>
</section>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script src="/assets/contact.js" defer></script>

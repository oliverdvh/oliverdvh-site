---
layout: base.njk
---

<section class="hero">
  <div class="container">
    <span class="eyebrow">{{ hero.eyebrow }}</span>
    <h1>{{ hero.headline }}</h1>
    <p class="lede mt-1">{{ hero.lede }}</p>
    <div class="hero-actions mt-2">
      <a class="btn btn-primary btn-arrow" href="{{ hero.primaryCtaUrl }}" target="_blank" rel="noopener">{{ hero.primaryCtaLabel }}</a>
      <a class="btn btn-secondary" href="{{ hero.secondaryCtaUrl }}" target="_blank" rel="noopener">{{ hero.secondaryCtaLabel }}</a>
    </div>
  </div>
</section>

<section class="section section-soft">
  <div class="container">
    <span class="eyebrow">{{ threads.eyebrow }}</span>
    <h2>{{ threads.heading }}</h2>
    <div class="cards mt-3">
      {% for c in threads.cards %}
      <article class="card">
        <span class="card-eyebrow">{{ c.eyebrow }}</span>
        <h4>{{ c.heading }}</h4>
        <p>{{ c.body }}</p>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <span class="eyebrow">{{ recent.eyebrow }}</span>
    <h2>{{ recent.heading }}</h2>
    <div class="writing-list mt-2" data-substack-feed="true" data-limit="6">
      {% for p in recent.fallbackPosts %}
      <a class="writing-item" href="{{ p.url }}" target="_blank" rel="noopener">
        <span class="writing-date">{{ p.date }}</span>
        <span class="writing-title">{{ p.title }}</span>
        <span class="writing-meta">Substack</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section-soft">
  <div class="container">
    <span class="eyebrow">{{ elsewhere.eyebrow }}</span>
    <h2>{{ elsewhere.heading }}</h2>
    <p class="lede mt-1" style="max-width: 60ch;">{{ elsewhere.lede }}</p>

    <div class="writing-list mt-2">
      {% for item in elsewhere.items %}
      <a class="writing-item" href="{{ item.url }}" target="_blank" rel="noopener">
        <span class="writing-date">{{ item.date }}</span>
        <span class="writing-title">{{ item.title }}</span>
        <span class="writing-meta">{{ item.meta }}</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <span class="eyebrow">{{ reports.eyebrow }}</span>
    <h2>{{ reports.heading }}</h2>
    <p class="lede mt-1" style="max-width: 62ch;">{{ reports.lede }}</p>

    <div class="reports">
      {% for r in reports.items %}
      <article class="report">
        <a class="report-cover" href="{{ r.pdf }}" target="_blank" rel="noopener" aria-label="Download {{ r.title }} PDF">
          <img src="{{ r.cover }}" alt="{{ r.coverAlt }}" loading="lazy" />
        </a>
        <div class="report-body">
          <span class="report-eyebrow">{{ r.meta }}</span>
          <h3 class="report-title">{{ r.title }}</h3>
          <p class="report-desc">{{ r.desc }}</p>
          <div class="report-actions">
            <a class="btn btn-primary btn-arrow" href="{{ r.pdf }}" target="_blank" rel="noopener">Download PDF</a>
            {% if r.original %}<a class="btn btn-secondary" href="{{ r.original }}" target="_blank" rel="noopener">Original page</a>{% endif %}
          </div>
        </div>
      </article>
      {% endfor %}
    </div>

    <p class="muted mt-4" style="font-family: var(--font-ui); font-size: 0.92rem;">Editors and producers — please use the <a href="/contact/">contact page</a>.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="subscribe-cta">
      <span class="eyebrow" style="color: rgba(255, 250, 242, 0.7);">{{ newsletter.eyebrow }}</span>
      <h2>{{ newsletter.heading }}</h2>
      <p>{{ newsletter.body }}</p>
      <a class="btn btn-primary btn-arrow" href="{{ site.substackUrl }}" target="_blank" rel="noopener">Subscribe on Substack</a>
    </div>
  </div>
</section>
